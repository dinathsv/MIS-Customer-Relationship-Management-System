# =============================================================================
# MIS Enterprise CRM Platform - Environment Configuration Example
# =============================================================================
# This file serves as a template for the environment variables required to run 
# the CRM platform. In the production environment, these are injected via 
# the docker-compose.yml file.

# -----------------------------------------------------------------------------
# 1. Sales Module (Port: 8086)
# -----------------------------------------------------------------------------
SALES_DB_HOST=salesdb
SALES_DB_PORT=5432
SALES_DB_USER=postgres
SALES_DB_PASSWORD=postgres123
SALES_DB_NAME=salesdb
SALES_JWT_SECRET=sales-module-secret-key-2026
SALES_BACKEND_PORT=8080

# -----------------------------------------------------------------------------
# 2. Complain Management Module (Port: 3000)
# -----------------------------------------------------------------------------
COMPLAIN_DB_URL=postgres://user:password@crm_complain_db:5432/crm_db?sslmode=disable
COMPLAIN_BACKEND_PORT=8081

# -----------------------------------------------------------------------------
# 3. User Management Module (Port: 8083)
# -----------------------------------------------------------------------------
USERMGMT_DB_HOST=usermgmt_db
USERMGMT_DB_PORT=5432
USERMGMT_DB_USER=myuser
USERMGMT_DB_PASSWORD=mypassword
USERMGMT_DB_NAME=user_db
USERMGMT_BACKEND_PORT=8082

# -----------------------------------------------------------------------------
# 4. Feedback Module (Port: 8085)
# -----------------------------------------------------------------------------
FEEDBACK_DB_URL=host=crm_feedback_db port=5432 user=crmuser password=crmpassword dbname=crmdb sslmode=disable
FEEDBACK_GIN_MODE=release
FEEDBACK_BACKEND_PORT=8084
